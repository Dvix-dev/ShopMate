# ────────────────────────────────────────────────────────────────────────────
#  .env.example — Plantilla conceptual.
#
#  ⚠️  AVISO para ShopMate: este proyecto es una webapp ESTÁTICA pura,
#      sin build step. Los archivos .env NO se pueden leer directamente
#      desde el navegador (el navegador no tiene acceso al sistema de
#      archivos del servidor).
#
#  La forma segura de externalizar la configuración Firebase en este
#  proyecto es:
#      · Copiar `firebase-config.example.js` a `firebase-config.local.js`
#      · Editar `firebase-config.local.js` con tus claves reales
#      · `firebase-config.local.js` está en `.gitignore`
#
#  Este .env.example se conserva por dos razones:
#      1. Documentar las variables en un formato familiar (estándar
#         de la industria) para equipos que migren a backend.
#      2. Preparar la migración futura a Firebase Hosting + Cloud Functions
#         (M5 en el roadmap), donde SÍ se pueden leer variables .env
#         desde el backend con un build step.
#
#  ⚠️  NUNCA pongas las claves reales en un archivo .env versionado.
#      Sólo `.env.example` se commitea, el resto está gitignored.
# ────────────────────────────────────────────────────────────────────────────

# Identificador del proyecto Firebase
FIREBASE_PROJECT_ID=

# Clave pública del cliente (web API key, ver consola de Firebase)
FIREBASE_API_KEY=

# ID de la app de Firebase (formato "1:NNNN:web:HHHH")
FIREBASE_APP_ID=

# Dominio de auth (suele ser "<projectId>.firebaseapp.com")
FIREBASE_AUTH_DOMAIN=

# URL completa de la Realtime Database
FIREBASE_DATABASE_URL=

# Bucket de Cloud Storage
FIREBASE_STORAGE_BUCKET=

# Sender ID para FCM (Firebase Cloud Messaging)
FIREBASE_MESSAGING_SENDER_ID=

# Google Analytics measurement ID (opcional)
FIREBASE_MEASUREMENT_ID=
